# ===========================================
# Nucha Website - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nucha?sslmode=require"

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=""

# App URL (dev: http://localhost:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin account (used for initial seed)
ADMIN_EMAIL="admin@nuchavill.com"

# SMTP (optional — for inquiry notification emails)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
